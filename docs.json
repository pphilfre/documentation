            "light": "#7a1295",
            "dark": "#7a1295"
          },
          "href": "https://markup.freddiephilpot.dev"
        },
        {
          "anchor": "Portfolio",
          "icon": "desktop",
          "color": {
            "light": "#7a1295",
            "dark": "#7a1295"
          },
          "href": "https://freddiephilpot.dev"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
