{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Markup",
  "colors": {
    "primary": "#ffffff",
    "light": "#7a1295",
    "dark": "#7a1295"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Markup",
          "icon": "book-open-cover",
